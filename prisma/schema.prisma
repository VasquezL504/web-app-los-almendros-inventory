generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InventoryItem {
  id            String   @id @default(cuid())
  name          String
  categories    String[]
  buyingDate    String
  expirationDate String
  amount        Float
  metric        String
  pricePerUnit  Float
  minAmount     Float?
  note          String   @default("")
  batchNumber   Int
  createdAt     String
  zeroedAt      String?

  @@index([name])
  @@index([expirationDate])
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
}

model AppState {
  id              String   @id @default("app_state")
  nameHistory     String[]
  nextBatchNumber Int      @default(1)
}

model Permissions {
  id                      String  @id @default("employee_permissions")
  
  // Ver detalles del producto en la lista
  showListCantidad        String  @default("yes")
  listCantidadDetail      Boolean @default(false)
  listValorTotalDetail    Boolean @default(false)
  listExpiracionDetail    Boolean @default(false)
  
  // Ver detalles del producto en la tarjeta completa
  showCardDetails         String  @default("yes")
  cardCantidad            Boolean @default(false)
  cardPrecioUnidad        Boolean @default(false)
  cardValorLote          Boolean @default(false)
  cardFechaCompra         Boolean @default(false)
  cardFechaExpiracion     Boolean @default(false)
  cardCantidadMinima      Boolean @default(false)
  
  // Editar información de productos
  allowEdit               String  @default("yes")
  editNombre              Boolean @default(false)
  editCategorias          Boolean @default(false)
  editFechaCompra         Boolean @default(false)
  editFechaExpiracion     Boolean @default(false)
  editCantidad            Boolean @default(false)
  editMetrica             Boolean @default(false)
  editPrecioUnidad        Boolean @default(false)
  editCantidadMinima      Boolean @default(false)
  editNota                Boolean @default(false)
  
  // Simple toggles
  canDeleteItems          Boolean @default(false)
  canManageCategories     Boolean @default(false)
  canUseRemoveDialog      Boolean @default(false)
  canViewTotalValue       Boolean @default(false)
  canExportExcel          Boolean @default(false)
  canBackupJSON           Boolean @default(false)
  canImportBackup         Boolean @default(false)
}
