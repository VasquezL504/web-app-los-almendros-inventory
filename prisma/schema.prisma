generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InventoryItem {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  categories    String[]
  buyingDate    String
  expirationDate String
  amount        Float
  metric        String
  pricePerUnit  Float
  minAmount     Float?
  note          String   @default("")
  batchNumber   Int
  createdAt     String
  zeroedAt      String?

  @@index([name])
  @@index([expirationDate])
}

model Category {
  id         String @id @default(cuid())
  businessId String @default("")
  name       String

  @@unique([businessId, name])
  @@index([businessId])
}

model AppState {
  id              String   @id @default("app_state")
  nameHistory     String[]
  nextBatchNumber Int      @default(1)
}

model Permissions {
  id                      String  @id @default("employee_permissions")
  
  // Ver detalles del producto en la lista
  showListCantidad        String  @default("yes")
  listCantidadDetail      Boolean @default(false)
  listValorTotalDetail    Boolean @default(false)
  listExpiracionDetail    Boolean @default(false)
  
  // Ver detalles del producto en la tarjeta completa
  showCardDetails         String  @default("yes")
  cardCantidad            Boolean @default(false)
  cardPrecioUnidad        Boolean @default(false)
  cardValorLote          Boolean @default(false)
  cardFechaCompra         Boolean @default(false)
  cardFechaExpiracion     Boolean @default(false)
  cardCantidadMinima      Boolean @default(false)
  
  // Editar información de productos
  allowEdit               String  @default("yes")
  canEditItems             Boolean @default(true)
  
  // Simple toggles
  canDeleteItems          Boolean @default(false)
  canManageCategories     Boolean @default(false)
  canUseRemoveDialog      Boolean @default(false)
  canViewTotalValue       Boolean @default(false)
  canExportExcel          Boolean @default(false)
  canBackupJSON           Boolean @default(false)
  canImportBackup         Boolean @default(false)
}

model Business {
  id   String @id
  name String
}

model Employee {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  role        String   @default("employee")
  isActive    Boolean  @default(true)
  businessIds String[]
  createdAt   DateTime @default(now())
}

model InventoryEvent {
  id             String  @id
  businessId     String
  itemName       String
  actorName      String?
  quantity       Float
  unitPrice      Float
  totalValue     Float
  type           String
  adjustmentKind String?
  note           String?
  occurredAt     String

  @@index([businessId])
  @@index([occurredAt])
}

model BackupSnapshot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  reason    String   @default("auto")
  checksum  String
  payload   Json

  @@index([createdAt])
  @@index([checksum])
}
